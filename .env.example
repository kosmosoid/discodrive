# Copy to .env and fill in. .env is NOT committed to git.

# === Infrastructure secrets — set at deploy time ===
# Postgres connection (host `postgres` = the docker-compose service name).
DATABASE_URL=postgres://disco:disco@postgres:5432/discodrive?sslmode=disable
# Session/JWT signing key (at least 32 random bytes). The server will NOT start with this
# placeholder. Generate with:  openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-secret
# Service base domain.
BASE_DOMAIN=localhost
# Encryption key for secret settings in the DB (AES-256-GCM, EXACTLY 32 bytes). Do NOT keep
# it in the same backup as the DB. The server will NOT start with this placeholder. Generate with:
#   openssl rand -hex 16
SETTINGS_ENCRYPTION_KEY=change-me-to-a-32-byte-secret!!!

# === Postgres container settings (docker-compose) ===
POSTGRES_USER=disco
POSTGRES_PASSWORD=disco
POSTGRES_DB=discodrive

# === Misc ===
APP_PORT=8080
# Data root inside the container (mirrors users' file trees).
STORAGE_ROOT=/data
# Background jobs: how many versions to keep, trash retention, rescan interval.
VERSION_KEEP=10
TRASH_DAYS=30
RESCAN_SECONDS=30
# File serving: true — via nginx (X-Accel-Redirect, zero-copy); false — Go streams it itself
# (for deploys without nginx). Behind nginx, keep this true.
XACCEL_ENABLED=true
